# ==========================================
# WINDOWS EVOLUTION SYSTEM
# Original → Windows 1.0 → Windows One
# Concept Build
# ==========================================

class WindowsOriginal:
    def __init__(self):
        self.version = "Windows Original"
        self.features = [
            "Prototype Window Layer",
            "Minimal GUI Concepts",
            "Basic Input Handling"
        ]
        self.state = "legacy"


class Windows1:
    def __init__(self):
        self.version = "Windows 1.0"
        self.features = [
            "Tile-Based GUI",
            "MS-DOS Integration",
            "Basic File Manager",
            "Mouse Support (Early)"
        ]
        self.state = "stable"


class WindowsOne:
    def __init__(self):
        self.version = "Windows One"
        self.features = [
            "Modern UI Shell",
            "Security Sandbox",
            "Process Isolation",
            "Virtual Memory Layer",
            "Performance Optimization Core"
        ]
        self.state = "upgraded"


class WindowsUpgradePipeline:
    def __init__(self):
        self.original = WindowsOriginal()
        self.win1 = Windows1()
        self.win_one = None
        self.logs = []

    def boot_original(self):
        self.logs.append(f"BOOT: {self.original.version}")
        return self.original

    def upgrade_to_win1(self):
        self.logs.append("UPGRADE: Original → Windows 1.0")
        return self.win1

    def upgrade_to_win_one(self):
        self.win_one = WindowsOne()
        self.logs.append("UPGRADE: Windows 1.0 → Windows One")
        return self.win_one

    def full_status(self):
        return {
            "original": self.original.features,
            "windows_1": self.win1.features,
            "windows_one": self.win_one.features if self.win_one else None,
            "logs": self.logs
        }


# =========================
# RUN PIPELINE
# =========================

system = WindowsUpgradePipeline()

system.boot_original()
system.upgrade_to_win1()
system.upgrade_to_win_one()

print(system.full_status())