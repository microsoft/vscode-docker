import { Alert } from "react-native";
import { DeviceSecurityCheck } from "./DeviceSecurityCheck";

export const enforceSecurityLock = async (onFailCallback) => {
  const result = await DeviceSecurityCheck();

  const compromised =
    result.isJailbroken ||
    result.isRooted ||
    result.isEmulator;

  if (compromised) {
    Alert.alert(
      "Security Blocked",
      "This device is not allowed to run this application.",
      [{ text: "Exit App" }]
    );

    if (onFailCallback) {
      onFailCallback(result);
    }

    return false;
  }

  return true;
};